generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MeetingStatus {
  scheduled
  live
  ended

  @@map("meeting_status_enum")
}

enum ParticipantRole {
  host
  co_host
  participant

  @@map("participant_role_enum")
}

enum ConnectionQuality {
  excellent
  good
  poor
  disconnected

  @@map("connection_quality_enum")
}

enum UserRole {
  admin
  member

  @@map("user_role_enum")
}

enum AuthProvider {
  email
  google
  github

  
}

model Organization {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  billing_tier String?   @default("free")
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at   DateTime? @db.Timestamptz(6)

  Users        User[]
  Meetings     Meeting[]
  MeetingRooms MeetingRoom[]

  @@map("organizations")
}

model User {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id          String?          @db.Uuid
  email           String           @unique
  password_hash   String?
  auth_provider   AuthProvider?    @default(email)
  is_verified     Boolean?         @default(false)
  role            UserRole?        @default(member)
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime?        @db.Timestamptz(6)

  Organization    Organization?    @relation(fields: [org_id], references: [id])
  HostedMeetings  Meeting[]        @relation("HostMeetings")
  MeetingRooms    MeetingRoom[]
  Participants    MeetingParticipant[]
  SentMessages    ChatMessage[]
  SentDirects     DirectMessage[]   @relation("SentDirects")
  ReceivedDirects DirectMessage[]   @relation("ReceivedDirects")
  Sessions        Session[]
  Profiles        UserProfile[]
  AuditLogs       AuditLog[]
  RateLimits      RateLimit[]

  @@map("users")
}

model MeetingRoom {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String       @db.Uuid
  owner_id      String       @db.Uuid
  name          String
  slug          String       @unique
  passcode_hash String?
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at    DateTime?    @db.Timestamptz(6)

  Organization  Organization @relation(fields: [org_id], references: [id])
  Owner         User         @relation(fields: [owner_id], references: [id])
  Meetings      Meeting[]

  @@map("meeting_rooms")
}

model Meeting {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id               String             @db.Uuid
  room_id              String?            @db.Uuid
  host_id              String             @db.Uuid
  title                String
  type                 String
  status               MeetingStatus      @default(scheduled)
  start_time           DateTime           @db.Timestamptz(6)
  end_time             DateTime?          @db.Timestamptz(6)
  max_participants     Int?               @default(100)
  is_recording_enabled Boolean?           @default(false)
  join_token           String             @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at           DateTime           @default(now()) @db.Timestamptz(6)
  updated_at           DateTime           @default(now()) @updatedAt @db.Timestamptz(6)

  Organization         Organization       @relation(fields: [org_id], references: [id])
  Room                 MeetingRoom?       @relation(fields: [room_id], references: [id])
  Host                 User               @relation("HostMeetings", fields: [host_id], references: [id])
  Participants         MeetingParticipant[]
  ChatMessages         ChatMessage[]
  Recordings           MeetingRecording[]
  Stats                MeetingStat?

  @@map("meetings")
}

model MeetingParticipant {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meeting_id         String             @db.Uuid
  user_id            String?            @db.Uuid
  guest_name         String?
  role               ParticipantRole    @default(participant)
  mic_state          Boolean?           @default(false)
  cam_state          Boolean?           @default(false)
  connection_quality ConnectionQuality? @default(good)
  device_type        String?
  join_time          DateTime           @default(now()) @db.Timestamptz(6)
  leave_time         DateTime?          @db.Timestamptz(6)

  Meeting            Meeting            @relation(fields: [meeting_id], references: [id])
  User               User?              @relation(fields: [user_id], references: [id])

  @@map("meeting_participants")
}

model ChatMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meeting_id String   @db.Uuid
  sender_id  String?  @db.Uuid
  content    String
  is_edited  Boolean? @default(false)
  is_deleted Boolean? @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  Meeting    Meeting  @relation(fields: [meeting_id], references: [id])
  Sender     User?    @relation(fields: [sender_id], references: [id])

  @@map("chat_messages")
}

model DirectMessage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id   String   @db.Uuid
  receiver_id String   @db.Uuid
  content     String
  is_edited   Boolean? @default(false)
  is_deleted  Boolean? @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  Sender      User     @relation("SentDirects", fields: [sender_id], references: [id])
  Receiver    User     @relation("ReceivedDirects", fields: [receiver_id], references: [id])

  @@map("direct_messages")
}

model MeetingRecording {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meeting_id       String   @db.Uuid
  file_url         String
  file_size        BigInt?
  storage_provider String?
  checksum         String?
  duration_seconds Int?
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  Meeting          Meeting  @relation(fields: [meeting_id], references: [id])

  @@map("meeting_recordings")
}

model MeetingStat {
  meeting_id             String    @id @db.Uuid
  peak_participants      Int?      @default(0)
  total_messages         Int?      @default(0)
  total_duration_seconds Int?      @default(0)
  updated_at             DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  Meeting                Meeting   @relation(fields: [meeting_id], references: [id])

  @@map("meeting_stats")
}

model Session {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String   @db.Uuid
  device_id          String?  @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ip_address         String?  @db.Inet
  user_agent         String?
  refresh_token_hash String
  expires_at         DateTime @db.Timestamptz(6)
  created_at         DateTime @default(now()) @db.Timestamptz(6)

  User               User     @relation(fields: [user_id], references: [id])

  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  action     String
  metadata   Json?    @db.JsonB
  ip_address String?  @db.Inet
  created_at DateTime @default(now()) @db.Timestamptz(6)

  User       User?    @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model MeetingEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meeting_id     String   @db.Uuid
  participant_id String   @db.Uuid
  event_type     String
  payload        Json?    @db.JsonB
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@map("meeting_events")
}

model RateLimit {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  ip_address String   @db.Inet
  action     String
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  User       User?    @relation(fields: [user_id], references: [id])

  @@map("rate_limits")
}

model UserProfile {
  user_id      String   @id @db.Uuid
  display_name String
  avatar_url   String?
  timezone     String?  @default("UTC")
  preferences  Json?    @db.JsonB
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  User         User     @relation(fields: [user_id], references: [id])

  @@map("user_profiles")
}
